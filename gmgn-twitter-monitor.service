[Unit]
Description=Gmgn Twitter Monitor Service
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/GmgnTwitterTgAlert
Environment="PATH=/root/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/root/.local/bin/uv run python -m gmgn_twitter_monitor
Restart=always
RestartSec=10
RuntimeMaxSec=43200
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
