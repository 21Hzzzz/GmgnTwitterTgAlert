# ==========================================
# GmgnTwitterTgAlert Telegram-only config
# Copy this file to .env and fill real values.
# ==========================================

# ---------- Optional proxy ----------
# Leave empty for direct connection. To use Cloudflare WARP proxy mode:
# PROXY_SERVER=socks5://127.0.0.1:40000
PROXY_SERVER=

# ---------- Telegram ----------
TG_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ123456789

# Default group receives every captured GMGN message when enabled.
TG_ENABLE_DEFAULT=True
TG_CHANNEL_ID_DEFAULT=-1002502507331

# Main group receives only messages that do not match any route group.
TG_ENABLE_MAIN=False
TG_CHANNEL_ID_MAIN=-5223401368

# ---------- Route groups ----------
# Each group uses the same suffix:
#   TG_ROUTING_<GROUP>     = handle1,handle2,...
#   TG_ENABLE_<GROUP>      = True/False
#   TG_CHANNEL_ID_<GROUP>  = Telegram target group/channel ID
#
# Routed messages are sent to the default group and matching route groups.
# Unrouted messages are sent to the default group and main group above.

TG_ROUTING_BN=cz,heyi,binancecn,binancezh,binancewallet,binancesquarecn,binance_announcement,cz_binance,heyibinance,binance,bnbchain,binanceus,bnbchainzh,binancefutures
TG_ENABLE_BN=False
TG_CHANNEL_ID_BN=-1002490671103

TG_ROUTING_T2=bitget,bitget_zh,bitgetwallet,bitgetwalletcn,gracybitget,okx,okxchinese,okxwallet_cn,star_okx
TG_ENABLE_T2=False
TG_CHANNEL_ID_T2=-5217606702

TG_ROUTING_ONCHAIN=aave,arkham,ethereum,ethereumfndn,lookonchain,moonshot,moonshotlisting,solana,vitalikbuterin,zachxbt
TG_ENABLE_ONCHAIN=False
TG_CHANNEL_ID_ONCHAIN=-5207064063

TG_ROUTING_MACRO=realdonaldtrump,durov,elonmusk,erictrump,sama,whitehouse
TG_ENABLE_MACRO=False
TG_CHANNEL_ID_MACRO=-5223545066

# Optional explicit allowlist. Leave empty to allow every captured handle.
# When set, only these handles are sent to any Telegram target.
TG_FILTER_HANDLES=

# Non-Twitter source handles such as Binance Square accounts.
# These handles use raw media URLs for Telegram large-image previews.
BINANCE_SQUARE_HANDLES=

# ---------- DeepSeek translation ----------
# Leave empty to disable translation.
DEEPSEEK_API_KEY=
DEEPSEEK_TRANSLATION_MODEL=deepseek-v4-flash
DEEPSEEK_SUMMARY_MODEL=deepseek-v4-pro
# Optional prompt overrides. Use literal \n for line breaks.
DEEPSEEK_TRANSLATION_PROMPT=
DEEPSEEK_SUMMARY_PROMPT=

# ---------- AI scheduled summaries ----------
# AI summaries use the same DeepSeek API key above.
# Messages are stored in SQLite before being summarized.
AI_SUMMARY_ENABLED=True
AI_SUMMARY_DB_PATH=
AI_SUMMARY_INTERVAL_MINUTES=20
AI_SUMMARY_TIMEOUT_SECONDS=120
AI_SUMMARY_MAX_RETRIES=3

# Enable summaries per Telegram target group. Each group can override the
# summary window; leave interval empty to use AI_SUMMARY_INTERVAL_MINUTES.
AI_SUMMARY_ENABLE_DEFAULT=True
AI_SUMMARY_INTERVAL_MINUTES_DEFAULT=

AI_SUMMARY_ENABLE_MAIN=False
AI_SUMMARY_INTERVAL_MINUTES_MAIN=

AI_SUMMARY_ENABLE_BN=False
AI_SUMMARY_INTERVAL_MINUTES_BN=

AI_SUMMARY_ENABLE_T2=False
AI_SUMMARY_INTERVAL_MINUTES_T2=

AI_SUMMARY_ENABLE_ONCHAIN=False
AI_SUMMARY_INTERVAL_MINUTES_ONCHAIN=

AI_SUMMARY_ENABLE_MACRO=False
AI_SUMMARY_INTERVAL_MINUTES_MACRO=
