# GMGN Telegram 群组推送配置
# 生产环境由 install.sh 写入 /etc/gmgn-twitter-monitor/gmgn.env

# 必填：Telegram BotFather 创建的 Bot Token
TG_BOT_TOKEN=123456789:replace-with-real-token

# 可选兜底群组。未命中任何路由组时才使用。
TG_ENABLE_DEFAULT=False
TG_CHANNEL_ID=-1001234567890

# 路由组：同名后缀必须一致，可添加任意数量的组。
TG_ROUTING_MAIN=cz_binance,heyibinance
TG_ENABLE_MAIN=True
TG_CHANNEL_ID_MAIN=-1001234567890
TG_TRACK_FILTER_MAIN=

TG_ROUTING_MUSK=elonmusk
TG_ENABLE_MUSK=False
TG_CHANNEL_ID_MUSK=-1001234567891
TG_TRACK_FILTER_MUSK=

# 一般留空；启用的 TG_ROUTING_* 会自动合并进监控白名单。
TG_FILTER_HANDLES=

# 非 Twitter 来源账号，使用 GMGN 原始图片链接生成预览。
BINANCE_SQUARE_HANDLES=cz,heyi
INSTAGRAM_TRANSLATION_ENABLE=False

# GMGN/浏览器网络代理。安装器会检测或协助配置 WARP。
PROXY_SERVER=socks5://127.0.0.1:40000
MONITOR_URL=https://gmgn.ai/follow?target=xTracker&chain=bsc
WATCHDOG_TIMEOUT=120
WATCHDOG_POLL_INTERVAL=5

# 上游 GMGN WebSocket 降噪与诊断；这不是下游分发渠道。
GMGN_BLOCK_WS_SUBSCRIBE_CHANNELS=chain_stat
GMGN_WS_FRAME_STATS_INTERVAL=600
GMGN_HEARTBEAT_LOG_INTERVAL=600
DIAG_HANDLES=

# DeepSeek 留空时只推送原文。
DEEPSEEK_API_KEY=
AI_ANALYZE_HANDLES=

# Telegram 定时摘要，默认关闭。
SUMMARY_ENABLE=False
SUMMARY_TIMEZONE=Asia/Shanghai
SUMMARY_TIMES=07:30,20:00
SUMMARY_GROUPS=MAIN
SUMMARY_LABEL_MAIN=主群
SUMMARY_MAX_TWEETS=120
SUMMARY_AI_TIMEOUT_SECONDS=180
SUMMARY_TWEET_TEXT_LIMIT=500
