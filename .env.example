# ==========================================
# GmgnTwitterTgAlert Telegram-only config
# Copy this file to .env and fill real values.
# ==========================================

# ---------- First login ----------
# Set FIRST_RUN_LOGIN=True only for the first authorization run, then set it
# back to False after browser_data has been created.
FIRST_RUN_LOGIN=False
AUTH_URL=

# ---------- Optional proxy ----------
# Leave empty for direct connection. To use Cloudflare WARP proxy mode:
# PROXY_SERVER=socks5://127.0.0.1:40000
PROXY_SERVER=

# ---------- Telegram ----------
TG_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ123456789

# Main group receives every captured GMGN message when enabled.
TG_ENABLE_MAIN=True
TG_MAIN_CHANNEL_ID=-1001234567890

# ---------- Route groups ----------
# Each group uses the same suffix:
#   TG_ROUTING_<GROUP>     = handle1,handle2,...
#   TG_ENABLE_<GROUP>      = True/False
#   TG_CHANNEL_ID_<GROUP>  = Telegram target group/channel ID
#
# Routed messages are also sent to the main group above.

# Binance-related group
TG_ROUTING_BINANCE=cz_binance,heyibinance,cz,heyi
TG_ENABLE_BINANCE=True
TG_CHANNEL_ID_BINANCE=-1001234567891

# Musk group
TG_ROUTING_MUSK=elonmusk
TG_ENABLE_MUSK=True
TG_CHANNEL_ID_MUSK=-1001234567892

# Optional explicit allowlist. Leave empty to allow every captured handle.
# When set, only these handles are sent anywhere, including the main group.
TG_FILTER_HANDLES=

# ---------- DeepSeek translation ----------
# Leave empty to disable translation.
DEEPSEEK_API_KEY=
